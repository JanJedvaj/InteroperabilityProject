{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Book",
  "description": "Schema for a single Book import document",
  "type": "object",
  "required": ["title", "pageCount"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": ["integer", "null"]
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "description": {
      "type": ["string", "null"],
      "maxLength": 4000
    },
    "pageCount": {
      "type": "integer",
      "minimum": 1
    },
    "excerpt": {
      "type": ["string", "null"],
      "maxLength": 4000
    },
    "publishDate": {
      "type": ["string", "null"]
    }
  }
}
